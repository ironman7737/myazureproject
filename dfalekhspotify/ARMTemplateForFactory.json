								"computeType": "General"
							},
							"traceLevel": "Fine"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": [],
				"lastPublishTime": "2026-05-02T16:47:01Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/sales_data')]",
				"[concat(variables('factoryId'), '/datasets/ds_sales_curated')]",
				"[concat(variables('factoryId'), '/dataflows/df_transformation_sales')]"
			]
		},
