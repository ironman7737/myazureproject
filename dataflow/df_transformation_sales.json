{
	"name": "df_transformation_sales",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sales_data",
						"type": "DatasetReference"
					},
					"name": "srcsales"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sales_curated",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "Category1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as short,",
				"          name as string,",
				"          age as short,",
				"          city as string,",
				"          product as string,",
				"          amount as integer,",
				"          date as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcsales",
				"srcsales filter(amount>20000) ~> filter1",
				"filter1 derive(category = 'high value') ~> Category1",
				"Category1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     truncate: true,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}